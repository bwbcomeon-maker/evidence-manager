#!/usr/bin/env bash

# 环境变量模板：请复制为 scripts/smoke_global_search.env 并按需修改。
# 脚本会优先从此文件读取配置，其次使用代码中的默认值。

# 后端基础地址（可选）。不配置时脚本会尝试从 backend/app/src/main/resources/application.properties
# 中读取 server.port（当前默认为 8081），最终默认值为 http://localhost:8080。
#export API_BASE="http://localhost:8081"

# 测试账号 A（必选，建议为本地开发管理员或普通用户）
# 请填写实际测试账号；若使用管理员，请确保其密码来自安全引导或恢复脚本传入值。
#   username: admin
#   password: <你的管理员密码>
export TEST_USER_A="bwb1"
export TEST_PASS_A="<请改为你的测试密码>"

# 测试账号 B（可选，用于权限对比 TC-09）
#export TEST_USER_B="some-user"
#export TEST_PASS_B="SomePassword123"

# 若无法/不希望在脚本中自动登录，可在此直接提供 Cookie 或 Bearer Token：
# 1) Session Cookie（优先级高于 Token）
#    形如：AUTH_COOKIE_A="JSESSIONID=xxxx; OTHER_COOKIE=yyy"
#export AUTH_COOKIE_A=""
#export AUTH_COOKIE_B=""
#
# 2) Bearer Token（本项目默认使用 Session，通常用不到，仅为通用兜底）
#export AUTH_TOKEN_A=""
#export AUTH_TOKEN_B=""

# 关键字配置（可选，若为空脚本会使用默认值）：
# - KEYWORD_TITLE：用于命中证据标题（示例数据中包含“项目1-图片证据”等，可以使用“项目”或“图片”等关键字）
# - KEYWORD_REALNAME：用于按 real_name 搜索（示例管理员 real_name 为“系统管理员”）
# - KEYWORD_USERNAME：用于按 username 搜索（示例管理员 username 为“admin”）
export KEYWORD_TITLE="项目"
export KEYWORD_REALNAME="系统管理员"
export KEYWORD_USERNAME="admin"

