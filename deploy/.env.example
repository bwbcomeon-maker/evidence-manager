# Timezone
TZ=Asia/Shanghai

# Public port
PUBLIC_HTTP_PORT=80

# PostgreSQL
POSTGRES_DB=evidence
POSTGRES_USER=evidence
POSTGRES_PASSWORD=ChangeThisDatabasePassword

# Host persistent directories
HOST_POSTGRES_DATA=/opt/evidence-manager/data/postgres
HOST_UPLOADS_DATA=/opt/evidence-manager/data/uploads

# Spring Boot runtime
SESSION_COOKIE_SECURE=false
APP_LOG_LEVEL=INFO
MYBATIS_LOG_LEVEL=WARN
JAVA_OPTS=-Xms256m -Xmx768m

# First admin bootstrap (set true only on first deployment or emergency recovery)
BOOTSTRAP_ADMIN_ENABLED=true
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=ChangeThisAdminPassword
BOOTSTRAP_ADMIN_REAL_NAME=系统管理员
