<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bwbcomeon.evidence.mapper.NotificationMapper">

    <resultMap id="BaseResultMap" type="com.bwbcomeon.evidence.entity.Notification">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="user_id" property="userId" jdbcType="BIGINT"/>
        <result column="type" property="type" jdbcType="VARCHAR"/>
        <result column="title" property="title" jdbcType="VARCHAR"/>
        <result column="body" property="body" jdbcType="VARCHAR"/>
        <result column="related_project_id" property="relatedProjectId" jdbcType="BIGINT"/>
        <result column="related_application_id" property="relatedApplicationId" jdbcType="BIGINT"/>
        <result column="link_path" property="linkPath" jdbcType="VARCHAR"/>
        <result column="read_at" property="readAt" jdbcType="TIMESTAMP"/>
        <result column="created_at" property="createdAt" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, user_id, type, title, body, related_project_id, related_application_id, link_path, read_at, created_at
    </sql>

    <insert id="insert" parameterType="com.bwbcomeon.evidence.entity.Notification"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO notification (user_id, type, title, body, related_project_id, related_application_id, link_path, read_at, created_at)
        VALUES (
            #{userId},
            #{type},
            #{title},
            #{body},
            #{relatedProjectId},
            #{relatedApplicationId},
            #{linkPath},
            #{readAt},
            COALESCE(#{createdAt}, CURRENT_TIMESTAMP)
        )
    </insert>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM notification
        WHERE id = #{id}
    </select>

    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM notification
        WHERE user_id = #{userId}
        <if test="unreadOnly != null and unreadOnly">
            AND read_at IS NULL
        </if>
        <if test="type != null and type != ''">
            AND type = #{type}
        </if>
        ORDER BY created_at DESC
        <if test="limit != null and limit > 0">
            LIMIT #{limit}
        </if>
    </select>

    <update id="markRead">
        UPDATE notification
        SET read_at = #{readAt}
        WHERE id = #{id}
    </update>

    <update id="markReadByUser">
        UPDATE notification
        SET read_at = #{readAt}
        WHERE id = #{id, jdbcType=BIGINT} AND user_id = #{userId, jdbcType=BIGINT}
    </update>

    <update id="markReadByIds">
        UPDATE notification
        SET read_at = #{readAt}
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </update>
</mapper>
